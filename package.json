{
  "name": "@mynameistito/codex-usage",
  "version": "1.1.1",
  "private": false,
  "description": "CLI for inspecting Codex usage windows and reset credits.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/codex-usage.git"
  },
  "bin": {
    "codex-usage": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "ultracite check",
    "changeset": "changeset",
    "changeset-add": "bun run ./scripts/add-changeset.ts",
    "dev": "bun run src/cli.ts",
    "fix": "ultracite fix",
    "knip": "knip",
    "prepare": "lefthook install",
    "release": "bun run ./scripts/publish.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "eslint-plugin-github": "^6.1.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "knip": "^6.25.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.4",
    "typescript": "^7.1.0-dev.20260708.3",
    "ultracite": "7.9.3"
  },
  "overrides": {
    "js-yaml": "4.2.0",
    "read-yaml-file": "2.1.0"
  },
  "packageManager": "bun@1.3.14"
}
