{
  "name": "@mynameistito/codex-usage",
  "version": "0.0.0",
  "private": false,
  "description": "CLI for inspecting Codex usage windows and reset credits.",
  "bin": {
    "codex-usage": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./native-preview": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target node --outfile dist/index.js --external effect && bun build ./src/cli.ts --target node --outfile dist/cli.js --external effect && bun run build:types",
    "build:types": "bunx tsgo -p tsconfig.build.json",
    "check": "ultracite check",
    "changeset": "changeset",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "publish-packages": "bun publish --access public",
    "test": "bun test __tests__",
    "typecheck": "tsgo --noEmit",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "effect": "^3.19.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260618.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
